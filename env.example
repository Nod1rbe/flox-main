# Hackathon / local OpenAI (do not put real keys in git).
#
# Or paste key in code (hackathon only): lib/core/openai/openai_hackathon_key.dart
# → kOpenAiHackathonInlineKey = 'sk-...'; do NOT push that to a shared remote.
#
# Easiest (desktop): copy this file to `.env` in the repo root and set:
#   OPENAI_API_KEY=sk-...
# Then from project folder: flutter run -d windows
#
# PowerShell (same session):
#   $env:OPENAI_API_KEY="sk-..."
#   flutter run -d windows
#
# Or compile-time:
#   flutter run -d windows --dart-define=OPENAI_API_KEY=sk-...
#
# Note: Flutter web -> api.openai.com is usually blocked by browser CORS; use Windows/macOS for direct calls.
